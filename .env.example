# Copy to .env and change every value before anything leaves your laptop.
# .env is git-ignored (see .gitignore). Production secrets NEVER come from a
# file — see lrs-design-v1.md §8.13.

LRS_IMAGE=lrs:dev
LRS_LOG_LEVEL=INFO

NEO4J_PASSWORD=change-me-neo4j
CLICKHOUSE_PASSWORD=change-me-clickhouse
VAULT_DB_PASSWORD=change-me-vault
REDIS_PASSWORD=change-me-redis

# Dev-only ingest token. In production these are issued per district via the
# admin UI (spec §10.5), stored as HMACs, and shown exactly once.
LRS_DEV_INGEST_TOKEN=dev-token-not-for-production

# --- Deferred for the architecture-proof MVP; kept here so the shape does not
# --- change when they come back. See the plan's "Deferred, explicitly".
# META_DB_PASSWORD=change-me-meta        # RBAC / audit / experiments (M4)
# MINIO_ROOT_USER=lrsadmin               # export bucket (M3+)
# MINIO_ROOT_PASSWORD=change-me-minio
# KEYCLOAK_PASSWORD=change-me-keycloak   # OIDC (M3+)
# GRAFANA_PASSWORD=change-me-grafana     # obs profile (M5)
